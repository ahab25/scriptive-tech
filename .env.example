# Public site URL
NEXT_PUBLIC_SITE_URL=https://scriptive.tech

# ── SMTP (contact form) ───────────────────────────────────────────────────────
# Where to deliver enquiries
CONTACT_EMAIL_TO=hello@scriptive.tech

# SMTP credentials — use your email provider's outgoing mail settings
# Google Workspace / Gmail
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use an App Password, not your login password)
# Zoho Mail
#   SMTP_HOST=smtp.zoho.com   SMTP_PORT=587
# cPanel / Hosting
#   SMTP_HOST=mail.scriptive.tech  SMTP_PORT=587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@scriptive.tech
SMTP_PASS=your_app_password_here

# ── AI Chatbot ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
